# 환경변수 예시 (0.1 규칙: 실제 값은 .env.local 에 두고 커밋 금지)
# 실제 사용 시 이 파일을 .env.local 로 복사해 값을 채운다.

# Supabase (프로젝트 설정 > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트에 노출·커밋 금지
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 기본 URL (링크·리다이렉트·이메일용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 트랜잭셔널 이메일 서비스 (Resend). 앱 알림 메일(문의·회신)을 우리 코드가 직접 발송할 때 사용.
# EMAIL_FROM 은 "이름 <주소>" 형식으로 발신자 이름 지정 가능.
EMAIL_API_KEY=
EMAIL_FROM=B2BB2G <noreply@b2bb2g.com>
# 참고: 인증 메일(가입확인·비번재설정)은 Supabase Custom SMTP(Resend SMTP)로 발송한다.
#       Supabase 대시보드에서 설정하며 여기 env 와 무관(DEPLOY.md 참조).
