# 환경변수 예시 (0.1 규칙: 실제 값은 .env.local 에 두고 커밋 금지)
# 실제 사용 시 이 파일을 .env.local 로 복사해 값을 채운다.

# Supabase (프로젝트 설정 > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트에 노출·커밋 금지
SUPABASE_SERVICE_ROLE_KEY=

# 사이트 기본 URL (링크·리다이렉트·이메일용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 트랜잭셔널 이메일 서비스 (예: Resend). 슬라이스 5에서 사용
EMAIL_API_KEY=
EMAIL_FROM=

# Supabase Auth Send Email Hook 시크릿 (대시보드에서 발급, 배포 후 설정)
# 형식 예: v1,whsec_XXXXXXXX
AUTH_EMAIL_HOOK_SECRET=
